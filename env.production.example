# ============================================================================
# AppForge SaaS — .env.production
# 
# IMPORTANTE: Este archivo debe estar en /opt/appforge/appforge-backend/.env
# Nunca commitar a Git. Permisos: 600 (solo lectura para root)
# 
# Generado: $(date)
# ============================================================================

# ============================================================================
# ENTORNO
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# BASE DE DATOS — PostgreSQL
# ============================================================================
# Credenciales de PostgreSQL
# Usuario: appforge
# Contraseña generada (random): EjemploD4t0sAleat0r10sFuert3sP@ssw0rd
DB_PASSWORD=EjemploD4t0sAleat0r10sFuert3sP@ssw0rd

# Connection string
DATABASE_URL="postgresql://appforge:EjemploD4t0sAleat0r10sFuert3sP@ssw0rd@localhost:5432/appforge_prod"

# ============================================================================
# REDIS — Cache y BullMQ
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT — Autenticación
# ============================================================================
# Generados con: openssl rand -base64 64
JWT_SECRET=EjemploJWT5ecr3tC0mpl3t0C0nRand0m1z4d0Y0K3yG3n3r4d0C0nOpenSSLq1w2e3r4t5y6u7i8o9p0
APP_USER_JWT_SECRET=EjemploAppUSER5ecr3tC0mpl3t0C0nRand0m1z4d0Y0K3yG3n3r4d0C0nOpenSSLq1w2e3r4t5y6u7i8o9

JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# ============================================================================
# ENCRIPTACIÓN — SMTP y Keystores
# ============================================================================
# Generados con: openssl rand -hex 32
# 32 bytes = 64 caracteres hexadecimales
SMTP_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1
KEYSTORE_ENCRYPTION_KEY=b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b

# ============================================================================
# MINIO — S3-compatible Storage
# ============================================================================
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=EjemploMinIOPassword123456
MINIO_BUCKET=appforge-artifacts

# ============================================================================
# API — URLs Públicas
# ============================================================================
# CRÍTICO: La URL del API es hardcodeada en los APKs generados
# Debe ser HTTPS en producción
PUBLIC_API_URL=https://api.creatu.app
PUBLIC_STORAGE_URL=https://storage.creatu.app
PUBLIC_BUILDER_URL=https://app.creatu.app
PUBLIC_ADMIN_URL=https://admin.creatu.app

# ============================================================================
# STRIPE — Pagos y Suscripciones
# ============================================================================
# Claves TEST (cambiar a LIVE cuando estés listo)
# Obtener desde: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY_HERE

# Modo de precios
STRIPE_MODE=test  # Cambiar a "live" en producción

# ============================================================================
# SENDGRID / NODEMAILER — Email
# ============================================================================
# Configuración SMTP para Postfix local
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=postfix
SMTP_PASSWORD=
SMTP_FROM=noreply@creatu.app
SMTP_TLS=false  # Postfix local no requiere TLS

# Alternativa: usar SendGrid
# SENDGRID_API_KEY=SG.YOUR_KEY_HERE
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.YOUR_KEY_HERE

# ============================================================================
# FIREBASE — Push Notifications (Fase 2)
# ============================================================================
# Dejar en blanco por ahora. Cuando actives FCM:
# 1. Crear proyecto en console.firebase.google.com
# 2. Descargar serviceAccountKey.json
# 3. Copiar contenido en esta variable (con comillas):
FIREBASE_SERVICE_ACCOUNT={}
FIREBASE_DATABASE_URL=

# ============================================================================
# GOOGLE OAUTH — Login Social
# ============================================================================
# Obtener desde: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://app.creatu.app/auth/google/callback

# ============================================================================
# BUILD PIPELINE — Android
# ============================================================================
# Rutas del sistema
ANDROID_SDK_ROOT=/opt/android-sdk
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
GRADLE_HOME=/opt/gradle/gradle-8.7

# Configuración de builds
BUILD_TIMEOUT_GRADLE=1500000  # 25 minutos en ms
BUILD_TIMEOUT_NPM=600000      # 10 minutos en ms
BUILD_MAX_MEMORY=2048         # MB para Gradle

# Caché
NPM_CONFIG_CACHE=/tmp/.npm-cache
GRADLE_USER_HOME=/tmp/.gradle-home

# ============================================================================
# WORKER — BullMQ
# ============================================================================
WORKER_MODE=separate  # "separate" = procesos API + Worker distintos
BullMQ_CONCURRENCY=1  # Máximo 1 build simultáneo (KVM 2)

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE=/var/log/appforge/app.log

# ============================================================================
# CORS — Seguridad
# ============================================================================
CORS_ORIGIN=https://app.creatu.app,https://admin.creatu.app

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000    # 1 minuto
RATE_LIMIT_MAX_REQUESTS=100   # Máximo 100 requests/minuto

# ============================================================================
# SESSION
# ============================================================================
SESSION_SECRET=EjemploSessionSecret123456789GeneatedAleatoriamente

# ============================================================================
# BACKUP
# ============================================================================
BACKUP_DIR=/backups/db
BACKUP_RETENTION_DAYS=30

# ============================================================================
# MODO DEBUG (Solo si necesitas troubleshooting)
# ============================================================================
DEBUG=appforge:*
VERBOSE=false
