# ============================================================================
# AppForge SaaS — Production .env template
#
# IMPORTANT: Copy this file to /opt/appforge/appforge-backend/.env
# DO NOT commit the real .env. Permissions: chmod 600 .env
#
# All values marked CHANGEME must be replaced before starting the app.
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# DATABASE — PostgreSQL
# ============================================================================
# Generate password: openssl rand -base64 32
DB_PASSWORD=CHANGEME_RUN_OPENSSL_RAND_BASE64_32

# Connection string (use the same DB_PASSWORD value)
DATABASE_URL="postgresql://appforge:CHANGEME_RUN_OPENSSL_RAND_BASE64_32@localhost:5432/appforge_prod"

# ============================================================================
# REDIS — Cache and BullMQ
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT — Authentication
# ============================================================================
# Generate each one with: openssl rand -base64 64
JWT_SECRET=CHANGEME_RUN_OPENSSL_RAND_BASE64_64
APP_USER_JWT_SECRET=CHANGEME_RUN_OPENSSL_RAND_BASE64_64

JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# ============================================================================
# ENCRYPTION — SMTP and Keystores (AES-256-GCM)
# ============================================================================
# Generate each one with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
SMTP_ENCRYPTION_KEY=CHANGEME_RUN_OPENSSL_RAND_HEX_32
KEYSTORE_ENCRYPTION_KEY=CHANGEME_RUN_OPENSSL_RAND_HEX_32

# ============================================================================
# MINIO — S3-compatible Storage (optional, only if using MinIO)
# ============================================================================
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=CHANGEME_MINIO_ADMIN_USER
MINIO_SECRET_KEY=CHANGEME_RUN_OPENSSL_RAND_BASE64_32
MINIO_BUCKET=appforge-artifacts

# ============================================================================
# API — Public URLs
# ============================================================================
# CRITICAL: API URL is hardcoded into generated APKs
# MUST be HTTPS in production
PUBLIC_API_URL=https://api.creatu.app
PUBLIC_STORAGE_URL=https://storage.creatu.app
PUBLIC_BUILDER_URL=https://app.creatu.app
PUBLIC_ADMIN_URL=https://admin.creatu.app

# ============================================================================
# STRIPE — Payments and Subscriptions
# ============================================================================
# TEST keys for now (switch to LIVE when ready)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=CHANGEME_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=CHANGEME_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=CHANGEME_STRIPE_WEBHOOK_SECRET

# Pricing mode
STRIPE_MODE=test

# ============================================================================
# SMTP — Email (Postfix or external provider)
# ============================================================================
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=postfix
SMTP_PASSWORD=
SMTP_FROM=noreply@creatu.app
SMTP_TLS=false

# Alternative: SendGrid
# SENDGRID_API_KEY=CHANGEME_SENDGRID_API_KEY
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=CHANGEME_SENDGRID_API_KEY

# ============================================================================
# FIREBASE — Push Notifications (Phase 2 — leave empty for now)
# ============================================================================
# When you enable FCM:
# 1. Create project at console.firebase.google.com
# 2. Download serviceAccountKey.json
# 3. Paste contents here as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT={}
FIREBASE_DATABASE_URL=

# ============================================================================
# GOOGLE OAUTH — Social Login (optional)
# ============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=CHANGEME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGEME_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://app.creatu.app/auth/google/callback

# ============================================================================
# BUILD PIPELINE — Android
# ============================================================================
ANDROID_SDK_ROOT=/opt/android-sdk
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
GRADLE_HOME=/opt/gradle/gradle-8.7

BUILD_TIMEOUT_GRADLE=1500000
BUILD_TIMEOUT_NPM=600000
BUILD_MAX_MEMORY=2048

NPM_CONFIG_CACHE=/tmp/.npm-cache
GRADLE_USER_HOME=/tmp/.gradle-home

# ============================================================================
# WORKER — BullMQ
# ============================================================================
WORKER_MODE=separate
BullMQ_CONCURRENCY=1

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE=/var/log/appforge/app.log

# ============================================================================
# CORS — Security
# ============================================================================
CORS_ORIGIN=https://app.creatu.app,https://admin.creatu.app

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# SESSION
# ============================================================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGEME_RUN_OPENSSL_RAND_BASE64_32

# ============================================================================
# BACKUP
# ============================================================================
BACKUP_DIR=/backups/db
BACKUP_RETENTION_DAYS=30

# ============================================================================
# DEBUG (only if troubleshooting)
# ============================================================================
DEBUG=
VERBOSE=false
